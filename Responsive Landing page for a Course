<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Course Landing Page</title>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        background: #f5f7fa;
    }

    header {
        background: #4a00e0;
        color: white;
        padding: 15px 50px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    header h1 {
        font-size: 24px;
    }

    nav a {
        color: white;
        margin-left: 20px;
        text-decoration: none;
        font-weight: bold;
    }

    nav a:hover {
        color: #ffd700;
    }

    .hero {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        padding: 50px;
        background: linear-gradient(to right, #8e2de2, #4a00e0);
        color: white;
    }

    .hero-text {
        max-width: 500px;
    }

    .hero h2 {
        font-size: 40px;
    }

    .hero p {
        margin: 15px 0;
    }

    .btn {
        display: inline-block;
        padding: 12px 20px;
        background: #ffd700;
        color: black;
        border-radius: 25px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn:hover {
        background: #ffc107;
    }

    .hero img {
        width: 400px;
        max-width: 100%;
    }

    .section {
        padding: 50px;
        text-align: center;
    }

    .cards {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
        margin-top: 20px;
    }

    .card {
        background: white;
        padding: 20px;
        width: 250px;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

    .card:hover {
        transform: translateY(-10px);
    }

    footer {
        background: #4a00e0;
        color: white;
        text-align: center;
        padding: 15px;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero {
            flex-direction: column;
            text-align: center;
        }

        header {
            flex-direction: column;
        }

        nav {
            margin-top: 10px;
        }
    }
</style>
</head>

<body>

<header>
    <h1>LearnHub 🎓</h1>
    <nav>
        <a href="#">Home</a>
        <a href="#">Courses</a>
        <a href="#">Features</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <div class="hero-text">
        <h2>Upgrade Your Skills Today 🚀</h2>
        <p>Join our online courses and become a professional developer.</p>
        <a href="#" class="btn">Get Started</a>
    </div>
    <img src="https://images.unsplash.com/photo-1581090700227-1e8a4b1b9b6f" alt="Learning">
</section>

<section class="section">
    <h2>Our Features</h2>
    <div class="cards">
        <div class="card">
            <h3>Expert Trainers</h3>
            <p>Learn from industry experts.</p>
        </div>
        <div class="card">
            <h3>Flexible Learning</h3>
            <p>Study anytime, anywhere.</p>
        </div>
        <div class="card">
            <h3>Certification</h3>
            <p>Get certified after completion.</p>
        </div>
    </div>
</section>

<section class="section">
    <h2>Popular Courses</h2>
    <div class="cards">
        <div class="card">
            <h3>Web Development</h3>
            <p>HTML, CSS, JavaScript</p>
        </div>
        <div class="card">
            <h3>Python Programming</h3>
            <p>Beginner to Advanced</p>
        </div>
        <div class="card">
            <h3>Data Science</h3>
            <p>AI & Machine Learning</p>
        </div>
    </div>
</section>

<section class="section">
    <h2>Contact Us</h2>
    <p>Email: learnhub@example.com</p>
    <p>Phone: +91 9876543210</p>
</section>

<footer>
    <p>© 2026 LearnHub | All Rights Reserved</p>
</footer>

</body>
</html>
