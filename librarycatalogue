<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Library Catalogue</title>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        background: linear-gradient(to right, #e0f7fa, #ffffff);
    }

    header {
        background: #00695c;
        color: white;
        padding: 20px;
        text-align: center;
        font-size: 26px;
    }

    .search-box {
        text-align: center;
        margin: 20px;
    }

    .search-box input {
        padding: 10px;
        width: 250px;
        border-radius: 20px;
        border: 1px solid #ccc;
    }

    .container {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
        padding: 20px;
    }

    .card {
        background: white;
        width: 250px;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        overflow: hidden;
        transition: 0.3s;
    }

    .card:hover {
        transform: scale(1.05);
    }

    .card img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }

    .card-content {
        padding: 15px;
    }

    .card-content h3 {
        color: #00695c;
    }

    .author {
        font-size: 14px;
        color: gray;
    }

    .btn {
        display: block;
        margin-top: 10px;
        padding: 8px;
        text-align: center;
        background: #00695c;
        color: white;
        border-radius: 20px;
        text-decoration: none;
    }

    .btn:hover {
        background: #004d40;
    }

    footer {
        text-align: center;
        padding: 10px;
        background: #00695c;
        color: white;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .search-box input {
            width: 80%;
        }
    }
</style>
</head>

<body>

<header>
    📚 Smart Library Catalogue
</header>

<div class="search-box">
    <input type="text" placeholder="🔍 Search books...">
</div>

<div class="container">

    <div class="card">
        <img src="https://images.unsplash.com/photo-1512820790803-83ca734da794" alt="">
        <div class="card-content">
            <h3>Python Programming</h3>
            <p class="author">Author: John Zelle</p>
            <a href="#" class="btn">View Details</a>
        </div>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1524995997946-a1c2e315a42f" alt="">
        <div class="card-content">
            <h3>Data Structures</h3>
            <p class="author">Author: Mark Allen Weiss</p>
            <a href="#" class="btn">View Details</a>
        </div>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1516979187457-637abb4f9353" alt="">
        <div class="card-content">
            <h3>Web Development</h3>
            <p class="author">Author: Jon Duckett</p>
            <a href="#" class="btn">View Details</a>
        </div>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1495446815901-a7297e633e8d" alt="">
        <div class="card-content">
            <h3>Artificial Intelligence</h3>
            <p class="author">Author: Stuart Russell</p>
            <a href="#" class="btn">View Details</a>
        </div>
    </div>

</div>

<footer>
    📖 Read More, Learn More | Contact: library@example.com
</footer>

</body>
</html>
